# Copy this file to .env, then replace the placeholders with your real sender mailbox.
# For Gmail, MAIL_PASSWORD must be an App Password, not your Gmail login password.

MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_without_spaces
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Cong sinh vien STU
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_QUEUE_CAPACITY=20000
MAIL_WORKER_COUNT=1
MAIL_SEND_DELAY_MS=1000
MAIL_MAX_RETRIES=2
MAIL_RETRY_DELAY_MS=5000

STUDENT_EMAIL_DOMAIN=student.edu.vn

PASSWORD_RESET_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_MONTHLY_LIMIT=2
