# Copy this file to .env, then replace placeholders only when you intentionally test mail sending.
# For Gmail, MAIL_PASSWORD must be an App Password, not your Gmail login password.
# The UI "Gửi email" checkbox only sends real email when MAIL_ENABLED=true
# and MAIL_USERNAME/MAIL_PASSWORD are valid SMTP credentials.

MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_without_spaces
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Cong sinh vien STU
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_QUEUE_CAPACITY=20000
MAIL_WORKER_COUNT=1
MAIL_SEND_DELAY_MS=1000
MAIL_MAX_RETRIES=2
MAIL_RETRY_DELAY_MS=5000

JWT_SECRET=replace_with_a_private_base64_256bit_secret
INTERNAL_SERVICE_SECRET=replace_with_a_private_internal_service_secret
GATEWAY_INTERNAL_SECRET=replace_with_a_private_gateway_internal_secret
APP_JWT_ACCESS_TOKEN_TTL_MINUTES=15
APP_AUTH_REFRESH_TOKEN_TTL_DAYS=7
APP_AUTH_REFRESH_COOKIE_SECURE=false
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax
# Test/debug only. Logs temporary generated passwords for single account creation and admin password reset.
APP_AUTH_LOG_TEMPORARY_CREDENTIALS=false

STUDENT_EMAIL_DOMAIN=student.edu.vn
APP_UPLOAD_MAX_SIZE_BYTES=10485760

PASSWORD_RESET_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_MONTHLY_LIMIT=2

# Optional one-time admin bootstrap for a fresh/local database.
# Keep disabled by default in committed examples.
# Copy to .env, set ENABLED=true, choose a strong private password, start auth-service once,
# then set ENABLED=false again after the admin account has been created.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin01
ADMIN_BOOTSTRAP_EMAIL=admin01@stu.edu.vn
ADMIN_BOOTSTRAP_PASSWORD=change_me_to_a_strong_private_password
